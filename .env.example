OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_KEEP_ALIVE=15m
WHISPER_COMMAND=whisper
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_CHUNK_DURATION_SECONDS=15
PREWARM_OLLAMA_ON_STARTUP=1
PREWARM_WHISPER_ON_STARTUP=1
HTTP_TIMEOUT_SECONDS=90
AUTH_MOBILE_CALLBACK_SCHEME=pikatakehome
AUTH_SESSION_TTL_SECONDS=2592000
# For Cloud Run, replace with your stable HTTPS domain:
# GOOGLE_OAUTH_CALLBACK_URL=https://api.example.com/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=

# Optional voice profile / TTS settings
FFMPEG_COMMAND=/usr/bin/ffmpeg
PIPER_COMMAND=
PIPER_MODEL_PATH=
PIPER_CONFIG_PATH=
COSYVOICE_COMMAND=
COSYVOICE_PYTHON=
COSYVOICE_REPO_DIR=
COSYVOICE_MODEL_DIR=
COSYVOICE_INFERENCE_MODE=zero_shot
COSYVOICE_PROMPT_TEXT=
COSYVOICE_INSTRUCT_TEXT=
COSYVOICE_INFERENCE_COMMAND=
COSYVOICE_ADAPTER_TRAIN_COMMAND=
COSYVOICE_ADAPTER_BASE_MODEL=
COSYVOICE_FINETUNED_TRAIN_COMMAND=
COSYVOICE_FINETUNED_BASE_MODEL_DIR=
COSYVOICE_FINETUNED_CONFIG_PATH=
COSYVOICE_FINETUNED_TRAIN_DATA=
COSYVOICE_FINETUNED_CV_DATA=
COSYVOICE_FINETUNED_COMPONENT=
COSYVOICE_FINETUNED_SPK_ID=
COSYVOICE_LANGUAGE=en
TTS_PROVIDER=auto
VOICE_PROFILE_MODELS_DIR=/app/data/profile-models
VOICE_PROFILE_MANIFESTS_DIR=/app/data/profiles
XTTS_MODEL_NAME=
XTTS_LANGUAGE=en
COQUI_TOS_AGREED=0
VOICE_PROFILE_TRAINING_COMMAND=
VOICE_PROFILE_TRAINING_MODE=xtts-reference
VOICE_PROFILE_TRAINING_TIMEOUT_SECONDS=900
